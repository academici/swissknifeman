{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(python *)",
      "Bash(python3 *)",
      "Bash(pip install *)",
      "Bash(pip3 install *)",
      "Bash(pip list *)",
      "Bash(pip show *)",
      "Bash(pip freeze *)",
      "Bash(pytest *)",
      "Bash(uv *)",
      "Bash(poetry *)",
      "Bash(ruff *)",
      "Bash(black *)",
      "Bash(mypy *)",
      "Bash(flake8 *)"
    ],
    "ask": [
      "Bash(pip uninstall *)",
      "Bash(poetry publish *)"
    ]
  }
}
