{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(node *)",
      "Bash(npm install *)",
      "Bash(npm ci *)",
      "Bash(npm run *)",
      "Bash(npm test *)",
      "Bash(npm exec *)",
      "Bash(npm ls *)",
      "Bash(npm outdated *)",
      "Bash(npx *)",
      "Bash(pnpm *)",
      "Bash(yarn *)",
      "Bash(tsc *)",
      "Bash(vitest *)",
      "Bash(eslint *)",
      "Bash(prettier *)"
    ],
    "ask": [
      "Bash(npm publish *)",
      "Bash(npm version *)"
    ],
    "deny": [
      "Read(node_modules/**)",
      "Read(**/*.lock)",
      "Read(dist/**)",
      "Read(build/**)",
      "Read(.next/**)",
      "Read(coverage/**)",
      "Read(**/*.min.js)",
      "Read(**/*.min.css)"
    ]
  }
}
